# Bloom API Quickstart — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Your Bloom API key
# Get one at https://trybloom.ai/developers
BLOOM_API_KEY=bloom_sk_your_key_here

# Optional: A brand URL to onboard if your account has no brands yet.
# Example: https://acme.com
BLOOM_BRAND_URL=
